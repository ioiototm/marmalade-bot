# Required
DISCORD_TOKEN=your_discord_bot_token_here

# Ollama endpoints
AWAKE_OLLAMA_URL=http://192.168.1.100:11434
SLEEP_OLLAMA_URL=http://host.docker.internal:11434

# Trigger words (comma-separated, word-boundary matched)
TRIGGER_WORDS=marmalade,mal

# Preferred models (comma-separated, tried in order)
AWAKE_MODELS=gemma4:26b,gemma3:27b,gemma4:e4b
SLEEP_MODELS=gemma3:270m

# Tuning
CONTEXT_MESSAGES=8
HEALTH_CHECK_MINS=60
MIN_MODEL_SIZE_GB=3.0
